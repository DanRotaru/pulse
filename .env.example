# Port the Express server listens on
PORT=3000

# Password required to view the dashboard and access the API/SSE endpoints
DASHBOARD_PASSWORD=12345

# Network interface to bind to. 0.0.0.0 exposes the dashboard to other devices
# on your LAN (phones, tablets, other PCs); use 127.0.0.1 to keep it local-only.
HOST=0.0.0.0
